# ============================================================
# Auth0 Configuration (MCP / ChatGPT)
# ============================================================

# Your Auth0 tenant domain
AUTH0_DOMAIN=your-tenant.us.auth0.com

# MCP Tools API identifier (agent authenticates against this)
# Register in Auth0 as a Resource Server with enforce_policies=true
# and tool-level scopes (tool:get_wishlist, tool:place_order, etc.)
AUTH0_MCP_AUDIENCE=https://app.retailzero.mvbuilt.com/mcp

# Resource API identifier (used in OBO token exchange)
# Register in Auth0 as a Resource Server with enforce_policies=true
# and resource-level scopes (read:wishlist, execute:purchase, etc.)
AUTH0_AUDIENCE=https://app.retailzero.mvbuilt.com/api

# MCP Server confidential client credentials (performs OBO exchange)
# Enable "On Behalf Of Token Exchange" on this application in Auth0
AUTH0_MCP_CLIENT_ID=your-mcp-client-id
AUTH0_MCP_CLIENT_SECRET=your-mcp-client-secret

# ============================================================
# Auth0 Configuration (UCP / Google)
# Generated by: npm run setup:ucp
# ============================================================

# UCP Identity Linking application (with CIBA)
AUTH0_UCP_CLIENT_ID=your-ucp-client-id
AUTH0_UCP_CLIENT_SECRET=your-ucp-client-secret

# Client-Initiated Backchannel Authentication
CIBA_ENABLED=false

# ============================================================
# Database (UCP only)
# ============================================================

# SQLite database directory (created by setup:ucp)
DATABASE_PATH=./data

# ============================================================
# Server
# ============================================================

PORT=3000

# Base URL for CIMD and OAuth callbacks
# Must match exactly where the app is hosted
APP_BASE_URL=http://localhost:3000

# ============================================================
# Auth0 Login (CIMD OAuth)
# ============================================================

# Auth0 tenant for user login (can be same as AUTH0_DOMAIN)
AUTH0_LOGIN_DOMAIN=your-tenant.auth0.com

# Session encryption key (generate with: openssl rand -hex 32)
AUTH0_SESSION_SECRET=generate-a-random-32-byte-hex-string

# ============================================================
# Redis (optional -- event log persistence, 7-day TTL)
# ============================================================

# REDIS_URL=redis://127.0.0.1:6379
